%% LOAD TO HERE

cd('D:\Tactile_Synchrony\2P-Data\Cleaned\datasets');
% load('dataset1_forFigures.mat');

load('dataset2_forFigures.mat');
% 2025-11-17: This dataset contains only neurons with more than 15 trials
% per condition & removed all neurons with trained effects


%% calculate preferred frequency per amplitude, selectivity & sel. metric (strength)

% SAVED IN ABOVE (2025-11-17)^^
pValThresh = 0.05;
for nn = 1 : size(Tc,1) % Loop neurons
    % preallocate variables for each neuron
    locResps = Tc.responses{nn}; % response values per trial
    locFreqs = Tc.frequencies{nn}; % frequency values per trial
    locAmps = Tc.amplitudes{nn}; % amplitude values per trial
    Tc.meanRespAF{nn} = zeros(length(ampValAll),length(freqVal)); % amps (5) x freqs (5)
    Tc.medianRespAF{nn} = zeros(length(ampValAll),length(freqVal)); % amps (5) x freqs (5)
    Tc.perfFreqPerAmp{nn} = zeros(length(ampValAll),1); % non-selective (0) or freq. sel (1-5)
    Tc.selMetricPerAmp{nn} = zeros(length(ampValAll),1); % selectivity strength per amp (5x1)
    for na = 1 : length(ampValAll) % loop amplitudes
        allResps = cell(length(freqVal),1); % responses per freq (5x1 cell)
        allFreqs = cell(length(freqVal),1); % freq labels (5x1 cell)
        for nf = 1 : length(freqVal) % loop frequencies
             allResps{nf} = locResps(locFreqs == freqVal(nf) & locAmps == ampValAll(na));
             allFreqs{nf} = repmat(nf,length(allResps{nf}),1);
        end
        Tc.meanRespAF{nn}(na,:) = cellfun(@mean,allResps)'; % extract mean response per freq
        Tc.medianRespAF{nn}(na,:) = cellfun(@median,allResps)'; % median response per freq
        [p,~] = anova1(cell2mat(allResps),cell2mat(allFreqs),'off'); % one-way anova for selectivity
        if p < pValThresh % Neuron has freq. selectivity
            [~,Tc.perfFreqPerAmp{nn}(na)] = max(Tc.meanRespAF{nn}(na,:)); % save pref. freq.
            % Tc.selMetricPerAmp{nn}(na) = quickSelectivity(Tc.meanRespAF{nn}(na,:)); % selectivity strength
            Tc.selMetricPerAmp{nn}(na) = quickSelectivityEntr(Tc.meanRespAF{nn}(na,:)); % selectivity strength
        end
    end
end

clear locResps locFreqs locAmps allResps allFreqs p tbl nn na nf
% save('dataset2_forFigures.mat','-v7.3');
disp("calculated selectivity strength");

%% NEURON COUNTS, BY CELL TYPE, AND BY SELECTIVITY TYPE

% SAVED IN ABOVE (2025-11-17)^^
num = struct(); % structure to hold neuron counts from all type combinations

% PV NEURONS COUNTS
num.PV = sum(is.PV);
num.unmodPV = sum(is.PV & is.nonMod); % unmodulated
num.freqPV = sum(is.PV & is.FreqMod & ~is.AmpMod & ~is.InterMod); % freq effect alone
num.ampPV = sum(is.PV & is.AmpMod & ~is.FreqMod & ~is.InterMod); % amp effect alone
num.dualPV = sum(is.PV & is.DualMod & ~is.InterMod); % dual modulated (2 main effects)
num.interPV = sum(is.PV & is.InterMod); % interaction effect

% SOM NEURON COUNTS
num.SOM = sum(is.SOM);
num.unmodSOM = sum(is.SOM & is.nonMod); % unmodulated
num.freqSOM = sum(is.SOM & is.FreqMod & ~is.AmpMod & ~is.InterMod); % freq effect alone
num.ampSOM = sum(is.SOM & is.AmpMod & ~is.FreqMod & ~is.InterMod); % amp effect alone
num.dualSOM = sum(is.SOM & is.DualMod & ~is.InterMod); % dual modulated (2 main effects)
num.interSOM = sum(is.SOM & is.InterMod); % interaction effect

% EXC NEURON COUNTS
num.EXC = sum(is.EXC);
num.unmodEXC = sum(is.EXC & is.nonMod); % unmodulated
num.freqEXC = sum(is.EXC & is.FreqMod & ~is.AmpMod & ~is.InterMod); % freq effect alone
num.ampEXC = sum(is.EXC & is.AmpMod & ~is.FreqMod & ~is.InterMod); % amp effect alone
num.dualEXC = sum(is.EXC & is.DualMod & ~is.InterMod); % dual modulated (2 main effects)
num.interEXC = sum(is.EXC& is.InterMod); % interaction effect


%% NEURON SELECTIVITY TYPES (PIE CHARTS)

figure('theme','light','color',[1 1 1]);
tiledlayout(1,3);
names = {"Freq. Effect","Amp. Effect","Dual Effect","Interaction Effect","No Effect"};

nexttile(1);
counts = [num.freqPV,num.ampPV,num.dualPV,num.interPV,num.unmodPV];
% piechart(counts,names,"Labels",names+"\newlinen="+string(counts),'FaceColor',colors.PV);
p1 = piechart(counts,names,"Labels",names+" ("+string(counts)+")",'FaceColor',colors.PV);

nexttile(2);
counts = [num.freqSOM,num.ampSOM,num.dualSOM,num.interSOM,num.unmodSOM];
% piechart(counts,names,"Labels",names+"\newlinen="+string(counts),'FaceColor',colors.SOM);
p2 = piechart(counts,names,"Labels",names+" ("+string(counts)+")",'FaceColor',colors.SOM);

nexttile(3);
counts = [num.freqEXC,num.ampEXC,num.dualEXC,num.interEXC,num.unmodEXC];
% piechart(counts,names,"Labels",names+"\newlinen="+string(counts),'FaceColor',colors.EXC);
p3 = piechart(counts,names,"Labels",names+" ("+string(counts)+")",'FaceColor',colors.EXC);


%% NEURON SELECTIVITY TYPES (BAR GRAPH)

figure('theme','light','color',[1 1 1]); hold on;
selTypes = ["unmod","freq","amp","dual","inter"];
selTypeNames = ["None","F","A","F + A","F * A"];
xVals = [1 2 3; 5 6 7; 9 10 11; 13 14 15; 17 18 19];
for ns = 2 : length(selTypes)
    for nc = 1 : length(cellType)
        locName = strcat(selTypes(ns),cellType(nc));
        yVal = num.(locName)/num.(cellType(nc)) * 100; 
        ySE = mannyPropSTD(num.(locName),num.(cellType(nc))) * 100;
        bar(xVals(ns,nc),yVal,'FaceColor',colors.(cellType(nc)))

        text(xVals(ns,nc),0,strcat(" n=",num2str(num.(locName))),'HorizontalAlignment',...
             'left','VerticalAlignment','middle','FontName','Arial','FontSize',8,'Rotation',90,'Color',[1 1 1]);
        errorbar(xVals(ns,nc),yVal,ySE,Color=[0,0,0],LineWidth=1);
    end
end
legend(["PV","","SOM","","EXC"],'box','off','FontName','Arial','location','northeast');
ylabel('Percentage of neurons','FontName','Arial');
xlabel('Effect type (2-way ANOVA)','FontName','Arial');
title("Response properties of all neurons by cell type",'FontName','Arial');
set(gca,'XTick',xVals(:,2),'XTickLabels',selTypeNames,'YLim',[0 20]);

%% NEURON SELECTIVITY TYPES ADDION OF INSET (BAR GRAPH)

figure('theme','light','color',[1 1 1]); hold on;
selTypes = ["freq","amp","dual","inter"];
selTypesNames = ["Freq.Sel.","Amp.Sel."];
xVals = [1 2 3; 5 6 7];
for nc = 1 : length(cellType)
    % FREQUENCY SELECTIVE (F, F+A, or F*A)
    locName1 = strcat(selTypes(2),cellType(nc)); % F
    locName3 = strcat(selTypes(4),cellType(nc)); % F+A
    locName3 = strcat(selTypes(5),cellType(nc)); % F*A
    locSum = num.(locName1) + num.(locName2) + num.(locName3);
    yVal = locSum /num.(cellType(nc)) * 100; 
    ySE = mannyPropSTD(locSum,num.(cellType(nc))) * 100;
    bar(xVals(ns,nc),yVal,'FaceColor',colors.(cellType(nc)))
    text(xVals(ns,nc),0,strcat(" n=",num2str(locSum)),'HorizontalAlignment',...
