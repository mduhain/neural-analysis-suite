%% Frequency tuning heatmaps
% ampNeuGrid = cat(2,Tc.perfFreqPerAmp{:}); % 0 == NonSelective
% selMetricGrid = cat(2,Tc.selMetricPerAmp{:}); % 0 == NonSelective
% meanRespMat = cat(3,Tc.meanRespAF{:}); % Amps(5) x Freqs(5) x Neurons(11000)

targetCellType = 3; % PV, SOM, EXC
figure('theme','light','color',[1 1 1]);
tiledlayout(1,5,'TileSpacing','tight','padding','tight');
% extract preferred freq by amp (dim.1) by neuron (dim.2)
for na = 1 : length(ampValAll)
    locHeatmap = [];
    for nf = 1 : length(freqVal)
        % indx = is.(cellType(targetCellType)) & is.allMod & prefFreqAll == nf;
        indx = (ampNeuGrid(na,:)==nf)' & is.(cellType(targetCellType));
        if sum(indx) == 0
            continue
        end
        locMat = squeeze(meanRespMat(na,:,indx))';
        [~,sIndx] = sort(selMetricGrid(na,indx));
        sortedMat = normalize(locMat(sIndx,:),2,'range');
        locHeatmap = cat(1,locHeatmap,sortedMat);
    end
    nexttile(na); hold on;
    imagesc(flip(locHeatmap,1));
    subtitle( strcat(num2str(ampValAll(na)),"\mum"),'FontName','Arial');
    set(gca,'XTick',1:5,'XTickLabel',freqVal,'XTickLabelRotation',45,'YLim',...
        [0 size(locHeatmap,1)],'FontName','Arial');
    set(gca,'YColor','none','FontName','Arial');
    if na == 1
        % newYTicks = round(sum(is.(cellType(nc)) & is.selective) .* (0:0.2:1));
        % set(gca,'YTick',newYTicks,'YTickLabel',flip(0:20:100),'FontName','Arial');
        ylabel('Percentage of neurons (%)','FontName','Arial');
    elseif na == 3
        title(strcat("Sorted frequency tuning: ",cellType(targetCellType)),...
            'FontName','Arial');
        % set(gca,'YColor','none','FontName','Arial');
        xlabel('Frequency (Hz)','FontName','Arial')
    else
        set(gca,'YColor','none','FontName','Arial');
    end
    hold off;
end


