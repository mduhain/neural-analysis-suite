%% SUPPLEMENT: NEURON SELECTIVITY STR BY AMP FROM EFFECT TYPES [MEAN + CI BANDS]
% 3 SEPRATE FIGRUES
% INPUTS 
xSp = 0.1; % X spacing for plotting
selMetricGrid = cat(2,Tc.selMetricPerAmp{:}); % 0 == NonSelective
xVals = [1 2 3; 6 7 8; 11 12 13; 16 17 18; 21 22 23]; 
xMat = repmat((1:5)',1,length(cellType))+repmat([xSp*-1 0 xSp],length(ampValAll),1);
xS = [-0.1 0 0.1]; % spacing in X
yMat = zeros(size(xMat));
allSelVals = cell(3,1);
allSelLabels = cell(3,1);
effType = ["FreqMod","DualMod","InterMod"]; % effect types (F, F+A, F*A)

% for nc = 1 : length(cellType)
%     plot(-1,-1,'.','MarkerSize',10,'Color',colors.(cellType(nc)));
% end


% DATA PLOTTING
for nc = 1 : length(cellType) % LOOP CELL TYPE 
    figure('theme','light','color',[1 1 1]); hold on;
    plot(-1,-1,'--','MarkerSize',10,'Color',colors.(cellType(nc)));
    plot(-1,-1,'-.','MarkerSize',10,'Color',colors.(cellType(nc)));
    plot(-1,-1,'-','MarkerSize',10,'Color',colors.(cellType(nc)));
    for nt = 1 : length(effType) % LOOP EFFECT TYPE 
        for na = 1 : length(ampValAll) % LOOP AMP
            indx = (selMetricGrid(na,:)~=0)' & is.(cellType(nc)) & is.(effType(nt));
            locSelVals = selMetricGrid(na,indx);
            allSelVals{nc} = cat(1,allSelVals{nc},locSelVals');
            allSelLabels{nc} = cat(1,allSelLabels{nc},repmat(ampValAll(na),length(locSelVals),1));
            yMat(na,nc) = mean(locSelVals);
            yCI = mkCI(locSelVals);
            errorbar(xMat(na,nc)+xS(nt),yMat(na,nc),yMat(na,nc)-yCI(1),yMat(na,nc)-yCI(2),...
                'Color',colors.(cellType(nc)),'LineWidth',1);
            plot(xMat(na,nc)+xS(nt),yMat(na,nc),'.','MarkerSize',10,'Color',colors.(cellType(nc)));
        end
        if nt == 1
            plot(xMat(:,nc)+xS(nt),yMat(:,nc),'--','Color',colors.(cellType(nc)),'LineWidth',0.8); % F connection line
        elseif nt == 2 
            plot(xMat(:,nc)+xS(nt),yMat(:,nc),'-.','Color',colors.(cellType(nc)),'LineWidth',0.8); % F+A connection line
        elseif nt == 3
            plot(xMat(:,nc)+xS(nt),yMat(:,nc),'-','Color',colors.(cellType(nc)),'LineWidth',0.8); % F+A connection line
        end
    end

    set(gca,'XTick',xMat(:,2),'XLim',[xMat(1)-(xSp*2) xMat(end)+(xSp*2)],...
        'XTickLabels',ampValAll,'FontName','Arial');
    xlabel("Amplitude (\mum)",'FontName','Arial');
    ylabel("Selectivity strength",'FontName','Arial');
    title(strcat(cellType(nc)," selectivity strength of effect types by amplitude"),'FontName','Arial');
    legend({'F','F+A','F*A'},'Location','northeast','Box','off','FontName','Arial');
end

