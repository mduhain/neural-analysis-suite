    b(k).CData = faceColors(k, :); % Assign the specified color
end

set(gca,'XTick',xMat(:),'XTickLabels',repmat(ampValAll,3,1),'XTickLabelRotation',45,...
    'YLim',[0 105],'YTickLabels',0:10:100,'XLim',[0 max(xMat(:))+xSp*2],'FontName','Arial');

