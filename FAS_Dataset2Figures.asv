    errorbar(xVals(ns,nc),yVal,ySE,Color=[0,0,0],LineWidth=1);
end
legend(["PV","","SOM","","EXC"],'box','off','FontName','Arial','location','northeast');
ylabel('Percentage of neurons','FontName','Arial');
xlabel('Effect type (2-way ANOVA)','FontName','Arial');
title("Response properties of all neurons by cell type",'FontName','Arial');
set(gca,'XTick',xVals(:,2),'XTickLabels',selTypesNames,'YLim',[0 20]);

%% NEURON SELECTIVITY CDFs

selMetricGrid = cat(2,Tc.selMetricPerAmp{:}); % 0 == NonSelective

for nc = 1 : length(cellType)
    % MAIN CDF PLOT BY AMPLITUDE
    figure('theme','light','color',[1 1 1]); hold on;
    for na = 1 : length(ampValAll)
        indx = (selMetricGrid(na,:)~=0)' & is.(cellType(nc));
        locSelVals = selMetricGrid(na,indx);
        [cdfEffectSize,xValuesCDF] = ecdf(locSelVals);
        plot(xValuesCDF,cdfEffectSize.*100,'LineWidth',1.5,'Color',colors.Amp(na,:));
    end
    legend(string(ampValAll),'box','off','FontName','Arial','location','northwest');
    ylabel('Percentage of neurons','FontName','Arial');
    xlabel('Selectivity metric','FontName','Arial');
    title(strcat(cellType(nc),": Frequency selectivity strength by amplitude"),'FontName','Arial');
    set(gca,'YLim',[0 101])
    hold off;

    % INSET PLOTS BY THIRDS
    figure('theme','light','color',[1 1 1]);
    tiledlayout(1,3);
    for na = 1 : length(ampValAll)
        indx = (selMetricGrid(na,:)~=0)' & is.(cellType(nc));
        locSelVals = selMetricGrid(na,indx);
        locSelValsSorted = sort(locSelVals);
        thirds = floor(length(locSelVals)/3);
        % Low third
        nexttile(1); hold on; 
        third1 = locSelValsSorted(1:thirds);
        plot([na na],mkCI(third1),'LineWidth',2,'Color',colors.Amp(na,:));
        plot(na,mean(third1),'k.','MarkerSize',12);
        hold off;
        % Middle third
        nexttile(2); hold on; 
        third2 = locSelValsSorted(thirds+1:(2*thirds));
        plot([na na],mkCI(third2),'LineWidth',2,'Color',colors.Amp(na,:));
        plot(na,mean(third2),'k.','MarkerSize',12)
        hold off;
        % High third
        nexttile(3); hold on; 
        third3 = locSelValsSorted((2*thirds)+1:end);
        plot([na na],mkCI(third3),'LineWidth',2,'Color',colors.Amp(na,:));
        plot(na,mean(third3),'k.','MarkerSize',12);
        hold off;
    end
    nexttile(1);
    title('bottom third','FontName','Arial');
    set(gca,'XLim',[0.5 5.1],'YTick',get(gca,'YLim'),'XColor','none','YLimMode','manual');
    ylabel('selectivity strength','FontName','Arial');
    nexttile(2);
    title('middle third','FontName','Arial');
    set(gca,'XLim',[0.5 5.1],'YTick',get(gca,'YLim'),'XColor','none','YLimMode','manual');
    nexttile(3);
    title('top third','FontName','Arial');
    set(gca,'XLim',[0.5 5.1],'YTick',get(gca,'YLim'),'XColor','none','YLimMode','manual');
end


%% NEURON SELECTIVITY STRENGTH BY AMP AS INDV GROUPS [MEAN + CI BANDS]
xSp = 0.1; % X spacing for plotting
selMetricGrid = cat(2,Tc.selMetricPerAmp{:}); % 0 == NonSelective
xVals = [1 2 3; 6 7 8; 11 12 13; 16 17 18; 21 22 23]; 
xMat = repmat((1:5)',1,length(cellType))+repmat([xSp*-1 0 xSp],length(ampValAll),1);
yMat = zeros(size(xMat));
allSelVals = cell(3,1);
allSelLabels = cell(3,1);
figure('theme','light','color',[1 1 1]); hold on;
for nc = 1 : length(cellType)
    plot(-1,-1,'.','MarkerSize',10,'Color',colors.(cellType(nc)));
end

permMat = cell(3,2); % celltype (1-3) x (selVals, amplitudes)
for nc = 1 : length(cellType) 
    for na = 1 : length(ampValAll)
        indx = (selMetricGrid(na,:)~=0)' & is.(cellType(nc));
        locSelVals = selMetricGrid(na,indx);
        permMat{nc,1} = cat(1,permMat{nc,1},locSelVals');
        locAmpVals = repmat(ampValAll(na),length(locSelVals),1);
        permMat{nc,2} = cat(1,permMat{nc,2},locAmpVals);
        allSelVals{nc} = cat(1,allSelVals{nc},locSelVals');
        allSelLabels{nc} = cat(1,allSelLabels{nc},repmat(ampValAll(na),length(locSelVals),1));
        yMat(na,nc) = mean(locSelVals);
        yCI = mkCI(locSelVals);
        errorbar(xMat(na,nc),yMat(na,nc),yMat(na,nc)-yCI(1),yMat(na,nc)-yCI(2),... % errorbars
            'Color',colors.(cellType(nc)),'LineWidth',1);
        plot(xMat(na,nc),yMat(na,nc),'.','MarkerSize',10,'Color',colors.(cellType(nc))); % mean value
    end
    tbl1 = table(xMat(:,nc),yMat(:,nc),'VariableNames',{'x','y'}); % fit mean vals (visualization only)
    f1 = fitlm(tbl1,'y ~ x'); % linear fit
    [yPred,yCI] = predict(f1,xMat(:,nc),'Alpha',0.05);
    plot(xMat(:,nc),yPred,'--','LineWidth',0.5,'Color',colors.(cellType(nc))); % fitted line
    % plot(xMat(:,nc),yCI(:,1),'--','Color',colors.(cellType(nc)),'') % lower bound
    % plot(xMat(:,nc),yCI(:,2),'--','Color',colors.(cellType(nc))) % upper bound
end

set(gca,'XTick',xMat(:,2),'XLim',[xMat(1)-(xSp*2) xMat(end)+(xSp*2)],...
    'XTickLabels',ampValAll,'FontName','Arial');
xlabel("Amplitude (\mum)",'FontName','Arial');
ylabel("Selectivity strength",'FontName','Arial');
title({'Frequency selectivity strength decreases at', 'higher amplitudes'},'FontName','Arial');
legend({'PV','SOM','EXC'},'Location','northeast','Box','off','FontName','Arial');

% PERMUTATION TESTS
numPerms = 1000;
allSlopes = zeros(numPerms,3);
p_values = zeros(length(cellType),1);
for nc = 1 : length(cellType)
    % calculate known (true) fit slope
    tbl1 = table(allSelLabels{nc},allSelVals{nc},'VariableNames',{'x','y'}); % fit to all values
    f1 = fitlm(tbl1,'y ~ x'); % linear fit from TRUE AMP VALUES
    trueSlope = f1.Coefficients.Estimate(2)

    % calculate permuted slopes
    for np = 1 : numPerms
        % permLabels = permMat{nc,2}(randperm(length(permMat{nc,1}))); % randomly shuffle x values
        % tbl = table(permLabels,permMat{nc,1},'VariableNames',{'x','y'}); 

        permValues = permMat{nc,1}(randperm(length(permMat{nc,1}))); % randomly shuffle y values
        tbl = table(permMat{nc,2},permValues,'VariableNames',{'x','y'}); 

        f0 = fitlm(tbl,'y ~ x');
        % f0 = fitlm(tbl,'y ~ logx');
        allSlopes(np,nc) = f0.Coefficients.Estimate(2);
    end
    locSE = std(allSlopes(:,nc))/sqrt(numPerms);
    locMean = mean(allSlopes(:,nc));
    locCIs = [locMean+(1.96*locSE) locMean-(1.96*locSE)];
    locZ = (trueSlope - locMean)/locSE;

    % pVal = (1 + sum(allSlopes(:,nc) < trueSlope)) / (1 + numPerms); % one-sided test (true slope is lower)
    pVal = (1 + sum( abs(allSlopes(:,nc)) > abs(trueSlope) )) / (1 + numPerms); % two-sided test
    p_values(nc) = pVal

    % % optional plotting
    % figure; histogram(allSlopes(:,nc)); hold on;
    % xline(locMean,'Color',[0 0 1]);
    % xline(locMean+(1.96*locSE));
    % xline(locMean-(1.96*locSE));
    % xline(trueSlope,'Color',[1 0 0]);
    % title(strcat(cellType(nc)," p-value = ",num2str(pVal))); hold off;
end

